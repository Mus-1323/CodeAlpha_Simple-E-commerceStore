<% layout("/layouts/boilerplate") %>

<div class="page-heading d-flex justify-content-between align-items-center">
  <div>
    <h2 class="h4 mb-1">Greaterhubs</h2>
    <p class="text-secondary mb-0">Shop Now And Visit Again</p>
  </div>
</div>

<div class="product-grid">
  <% for (let product of allList) { %>
    <div class="col">
      <div class="card product-card">
        <a href="/product/<%= product._id %>" class="product-img-wrap">
          <img
            src="<%= product.image %>"
            class="product-img"
            alt="<%= product.title %>"
            onerror="this.src='https://images.unsplash.com/photo-1557821552-17105176677c?auto=format&fit=crop&w=900&q=80'"
          >
        </a>

        <div class="card-body product-body d-flex flex-column">
          <div class="d-flex justify-content-between align-items-start gap-2">
            <span class="category-badge"><%= product.category %></span>
            <span class="product-price">Rs. <%= product.price.toLocaleString("en-IN") %></span>
          </div>

          <h3 class="product-title">
            <a href="/product/<%= product._id %>" class="product-link"><%= product.title %></a>
          </h3>
          <p class="product-description"><%= product.description %></p>

          <a href="/product/<%= product._id %>" class="btn btn-dark cart-btn w-100 mt-auto">View Details</a>
        </div>
      </div>
    </div>
  <% } %>
</div>
